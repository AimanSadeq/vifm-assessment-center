# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Canonical public URL used in outbound email links (invitation, personal
# results, consultant completion notifications). Set in Render to the
# production hostname. NEXT_PUBLIC_APP_URL is read by the personal-
# results email path; SITE_URL is read by the invitation email path.
# Both should point at the same origin.
# NEXT_PUBLIC_SITE_URL=https://caliber.viftraining.com
# NEXT_PUBLIC_APP_URL=https://caliber.viftraining.com

# Retention cron bearer token. The /api/ara/admin/retention/cron route
# refuses requests without "Authorization: Bearer ${CRON_SECRET}".
# Set the same value in TWO places:
#   1. Render env vars (so the route can verify the bearer at request time)
#   2. GitHub repo Actions secrets (so .github/workflows/ara-retention-
#      purge.yml can attach it to the daily 03:00 UTC scheduled curl)
# Generate with `openssl rand -hex 32`. Treat as a secret.
# CRON_SECRET=long-random-string

# Sandbox email redirect. When set, every ARA outbound email is sent to
# this address instead of the real recipient. Leave unset in production.
# SANDBOX_EMAIL_REDIRECT=qa-inbox@viftraining.com

# AI (Anthropic Claude API)
# ANTHROPIC_API_KEY=your-anthropic-api-key

# Video (Daily.co)
# DAILY_API_KEY=your-daily-api-key

# Email (Microsoft Graph API / Outlook)
# AZURE_TENANT_ID=your-azure-tenant-id
# AZURE_CLIENT_ID=your-app-client-id
# AZURE_CLIENT_SECRET=your-app-client-secret
# EMAIL_FROM_ADDRESS=noreply@viftraining.com
