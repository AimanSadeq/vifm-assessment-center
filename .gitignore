# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local scratch (frame extraction, audio, temp work)
.tmp/

# Claude Code local-only state — should never be committed.
# (.claude/settings.json is the shared, committed config.)
.claude/settings.local.json
.claude/launch-*.json
